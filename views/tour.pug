extends base
include _reviewCard

block append head
  script(src='https://api.mapbox.com/mapbox-gl-js/v3.2.0/mapbox-gl.js')
  link(rel='stylesheet' href='https://api.mapbox.com/mapbox-gl-js/v3.2.0/mapbox-gl.css')

mixin overviewBox(label, text, icon)
  .overview-box__detail
    svg.overview-box__icon
      use(xlink:href=`/img/icons.svg#icon-${icon}`)
    span.overview-box__label= label
    span.overview-box__text= text

block content
  section.section-header
    .header__hero
      .header__hero-overlay &nbsp;
      img.header__hero-img(src=`/img/tours/${tour.imageCover}`, alt=`${tour.name}`)

    .heading-box
      h1.heading-primary
        span=`${tour.name} tour`
      .heading-box__group
        .heading-box__detail
          svg.heading-box__icon
            use(xlink:href='/img/icons.svg#icon-clock')
          span.heading-box__text=`${tour.duration} days`
        .heading-box__detail
          svg.heading-box__icon
            use(xlink:href='/img/icons.svg#icon-map-pin')
          span.heading-box__text= tour.startLocation.address.split(',')[3] ? `${tour.startLocation.address.split(',')[1]}, ${tour.startLocation.address.split(',')[3]}` : tour.startLocation.description

  section.section-description
    .overview-box
      div
        .overview-box__group
          h2.heading-secondary.ma-bt-lg Quick facts
          - const date = tour.startDates && tour.startDates[0] ? tour.startDates[0].toLocaleString("en-us", {month: "long", year: "numeric"}) : "Coming Soon"

          +overviewBox("Next date", date, "calendar")
          +overviewBox("difficulty", tour.difficulty, "trending-up")
          +overviewBox("participants", `${tour.maxGroupSize} people`, "user")
          +overviewBox("Rating", `${tour.ratingsAverage} / 5`, "star")

        .overview-box__group
          h2.heading-secondary.ma-bt-lg Your tour guides
          each guide in tour.guides
            .overview-box__detail
              img.overview-box__img(src=`/img/users/${guide.photo}`, alt=`${guide.name}`)
              - if (guide.role === "lead-guide")
                span.overview-box__label Lead guide
              - if (guide.role === "guide")
                span.overview-box__label Tour guide
              span.overview-box__text= guide.name

    .description-box
      h2.heading-secondary.ma-bt-lg= `About ${tour.name} tour`
      - const paragraphs = tour.description ? tour.description.split("\n") : ["No description available for this tour yet."]
      each p in paragraphs
        p.description__text= p

  section.section-pictures
    each img, i in tour.images
      .picture-box
        img.picture-box__img(src=`/img/tours/${img}`, alt=`${tour.name} Tour ${i + 1}`, class=`picture-box__img--${i + 1}`)

  section.section-map
    #map(data-locations=`${JSON.stringify(tour.locations)}`, data-mapbox-token=mapboxToken)

  section.section-reviews
    //- THE EXPERIENCE CONDITIONAL GATEWAY: Only shows if trip is completed!
    if user && isExperienced
      .reviews__form-container(style="max-width: 60rem; margin: 0 auto 5rem auto; background-color: #fff; padding: 4rem; border-radius: 5px; box-shadow: 0 2rem 6rem rgba(0,0,0,0.06);")
        h2.heading-secondary.ma-bt-md Share Your Experience! ⭐
        form.form.form--review(data-tour-id=tour.id)
          .form__group.ma-bt-md
            label.form__label(for='rating') Rating (1-5 Stars)
            select#review-rating.form__input(style="font-family: inherit; font-size: 1.5rem; padding: 1.25rem 1.75rem;", required)
              option(value='5') 5 - Exceptional
              option(value='4') 4 - Very Good
              option(value='3') 3 - Average
              option(value='2') 2 - Disappointing
              option(value='1') 1 - Terrible
          .form__group.ma-bt-md
            label.form__label(for='review-text') Your Review
            textarea#review-text.form__input(placeholder='Tell us about the guides, the sights, and your overall adventure...', required, rows='4', style='font-family: inherit; resize: vertical;')
          .form__group
            button.btn.btn--green.btn--small Submit Review

    .reviews
      each review in tour.reviews
        +reviewCard(review)


  section.section-cta
    .cta
      .cta__img.cta__img--logo
        img(src='/img/logo-white.png', alt='Natours logo')
      img.cta__img.cta__img--1(src=`/img/tours/${tour.images[1]}`, alt='Tour picture')
      img.cta__img.cta__img--2(src=`/img/tours/${tour.images[2]}`, alt='Tour picture')
      .cta__content
        h2.heading-secondary What are you waiting for?
        p.cta__text= `${tour.duration} days. 1 adventure. Infinite memories. Make it yours today!`

        //- 🚀 NESTING ARCHITECTURE: Every conditional gate is aligned exactly right!
        if user
          if isBooked
            span.btn.btn--green.span-all-rows(style="background-image: linear-gradient(to right, #7dd56f, #28b485); cursor: default; box-shadow: none;")(href=`/me`) You already booked this tour! 🎉
          else
            button.btn.btn--green.span-all-rows#book-tour(data-tour-id=`${tour.id}` data-stripe-public-key=`${stripePublicKey}`) Book tour now!
        else 
          a.btn.btn--green.span-all-rows(href=`/login`) Log in to book tour
